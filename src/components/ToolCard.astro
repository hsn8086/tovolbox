---
import type { Locale } from '@/data/locales';
import { getPageCopy } from '@/data/pageCopy';
import type { Tool } from '@/data/types';
import { getLocalizedPath } from '@/lib/i18n/routing';

type Props = { tool: Tool; locale: Locale };
const { tool, locale } = Astro.props;
const seo = tool.seo[locale];
const pageCopy = getPageCopy(locale);
---

<a class="card" href={getLocalizedPath({ locale, kind: 'tool', slug: tool.slug })} style="display: block; padding: 1.1rem;">
  <span class="badge">{tool.status === 'live' ? pageCopy.liveToolBadge : pageCopy.guideBadge}</span>
  <h3 style="margin: .8rem 0 .35rem; font-size: 1.05rem;">{seo.h1}</h3>
  <p style="margin: 0; color: var(--muted); line-height: 1.55;">{seo.description}</p>
</a>
