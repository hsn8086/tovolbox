---
import ToolRegistry from '@/islands/tools/ToolRegistry.tsx';
import type { Locale } from '@/data/locales';
import { getPageCopy } from '@/data/pageCopy';

type Props = {
  component?: string;
  title: string;
  locale: Locale;
};

const { component, title, locale } = Astro.props;
const pageCopy = getPageCopy(locale);
---

{component ? <ToolRegistry client:load component={component} title={title} privacyNote={pageCopy.toolPrivacyNote} ymylDisclaimer={pageCopy.ymylDisclaimer} /> : (
  <section class="card" style="padding: 1.25rem;">
    <p>{pageCopy.ymylDisclaimer}</p>
  </section>
)}
