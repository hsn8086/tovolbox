---
import ToolIsland from '@/components/ToolIsland.astro';
import ToolCard from '@/components/ToolCard.astro';
import { getCategory, getTool, tools } from '@/data/content';
import { localeCopy } from '@/data/locales';
import { getPageCopy } from '@/data/pageCopy';
import { getToolSeoSections } from '@/data/seoContent';
import BaseLayout from '@/layouts/BaseLayout.astro';
import { getCanonicalUrl, getLocalizedPath } from '@/lib/i18n/routing';
import { breadcrumbJsonLd, faqJsonLd, toolJsonLd } from '@/lib/seo/jsonld';

export function getStaticPaths() { return tools.map((tool) => ({ params: { slug: tool.slug } })); }
const locale = 'en';
const tool = getTool(Astro.params.slug!)!;
const seo = tool.seo[locale];
const copy = localeCopy[locale];
const pageCopy = getPageCopy(locale);
const category = getCategory(tool.categorySlug)!;
const categorySeo = category.seo[locale];
const sections = getToolSeoSections(tool, locale);
const related = tool.relatedToolSlugs.map((slug) => getTool(slug)).filter((item) => item !== undefined);
const breadcrumbItems = [
  { name: copy.siteName, url: getCanonicalUrl({ locale, kind: 'home' }) },
  { name: categorySeo.h1, url: getCanonicalUrl({ locale, kind: 'category', slug: category.slug }) },
  { name: seo.h1, url: getCanonicalUrl({ locale, kind: 'tool', slug: tool.slug }) },
];
---
<BaseLayout locale={locale} title={seo.title} description={seo.description} route={{ locale, kind: 'tool', slug: tool.slug }} jsonLd={[toolJsonLd(seo.h1, seo.description, Astro.url.toString()), breadcrumbJsonLd(breadcrumbItems), faqJsonLd(seo.faq)]}>
  <section class="container" style="padding: 3rem 0; display: grid; gap: 1.25rem;">
    <nav aria-label="Breadcrumb" style="color: var(--muted); font-weight: 700;"><a href={getLocalizedPath({ locale, kind: 'home' })}>{copy.siteName}</a> / <a href={getLocalizedPath({ locale, kind: 'category', slug: category.slug })}>{categorySeo.h1}</a> / <span>{seo.h1}</span></nav>
    <div><span class="badge">{tool.status === 'live' ? pageCopy.liveToolBadge : pageCopy.guideBadge}</span><h1 style="font-size: clamp(2rem, 6vw, 4rem); margin: 1rem 0;">{seo.h1}</h1><p style="color: var(--muted); max-width: 820px; line-height: 1.75; font-size: 1.1rem;">{seo.intro}</p></div>
    {tool.isLocalOnly && <aside class="card" style="padding: 1rem;"><strong>{copy.privacy}:</strong> {copy.localOnly}</aside>}
    {tool.isYMYL && <aside class="card" style="padding: 1rem; border-color: #fbbf24;">{pageCopy.ymylDisclaimer}</aside>}
    <ToolIsland component={tool.component} title={seo.h1} locale={locale} />
    <section class="card" style="padding: 1.25rem;"><h2>{pageCopy.useCases}</h2><ul>{seo.useCases.map((item) => <li>{item}</li>)}</ul></section>
    <div class="grid-auto">{sections.map((section) => <section class="card" style="padding: 1.25rem;"><h2>{section.heading}</h2><p style="color: var(--muted); line-height: 1.7;">{section.body}</p><ul>{section.items.map((item) => <li>{item}</li>)}</ul></section>)}</div>
    <section class="card" style="padding: 1.25rem;"><h2>{copy.howToUse}</h2><ol>{seo.howToUse.map((item) => <li>{item}</li>)}</ol></section>
    <section class="card" style="padding: 1.25rem;"><h2>{copy.faq}</h2>{seo.faq.map((item) => <details><summary>{item.question}</summary><p>{item.answer}</p></details>)}</section>
    {related.length > 0 && <section><h2>{copy.relatedTools}</h2><div class="grid-auto">{related.map((item) => <ToolCard tool={item} locale={locale} />)}</div></section>}
  </section>
</BaseLayout>
