---
import ToolIsland from '@/components/ToolIsland.astro';
import ToolCard from '@/components/ToolCard.astro';
import { getTool, tools } from '@/data/content';
import { localeCopy } from '@/data/locales';
import BaseLayout from '@/layouts/BaseLayout.astro';
import { faqJsonLd, toolJsonLd } from '@/lib/seo/jsonld';

export function getStaticPaths() { return tools.map((tool) => ({ params: { slug: tool.slug } })); }
const locale = 'en';
const tool = getTool(Astro.params.slug!)!;
const seo = tool.seo[locale];
const copy = localeCopy[locale];
const related = tool.relatedToolSlugs.map((slug) => getTool(slug)).filter((item) => item !== undefined);
---
<BaseLayout locale={locale} title={seo.title} description={seo.description} route={{ locale, kind: 'tool', slug: tool.slug }} jsonLd={[toolJsonLd(seo.h1, seo.description, Astro.url.toString()), faqJsonLd(seo.faq)]}>
  <section class="container" style="padding: 3rem 0; display: grid; gap: 1.25rem;">
    <div><span class="badge">{tool.status === 'live' ? 'Live tool' : 'Guide'}</span><h1 style="font-size: clamp(2rem, 6vw, 4rem); margin: 1rem 0;">{seo.h1}</h1><p style="color: var(--muted); max-width: 820px; line-height: 1.75; font-size: 1.1rem;">{seo.intro}</p></div>
    {tool.isLocalOnly && <aside class="card" style="padding: 1rem;"><strong>{copy.privacy}:</strong> {copy.localOnly}</aside>}
    {tool.isYMYL && <aside class="card" style="padding: 1rem; border-color: #fbbf24;">This tool is for self-reflection and educational purposes only. It is not a medical diagnosis, clinical psychological assessment, or substitute for care from a qualified mental health professional.</aside>}
    <ToolIsland component={tool.component} title={seo.h1} />
    <section class="card" style="padding: 1.25rem;"><h2>{copy.howToUse}</h2><ol>{seo.howToUse.map((item) => <li>{item}</li>)}</ol></section>
    <section class="card" style="padding: 1.25rem;"><h2>{copy.faq}</h2>{seo.faq.map((item) => <details><summary>{item.question}</summary><p>{item.answer}</p></details>)}</section>
    {related.length > 0 && <section><h2>{copy.relatedTools}</h2><div class="grid-auto">{related.map((item) => <ToolCard tool={item} locale={locale} />)}</div></section>}
  </section>
</BaseLayout>
