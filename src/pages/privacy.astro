---
import BaseLayout from '@/layouts/BaseLayout.astro';
const locale = 'en';
---
<BaseLayout locale={locale} title="Privacy Policy | TovolBox" description="How TovolBox handles local browser tools and user privacy." route={{ locale, kind: 'privacy' }}><section class="container" style="padding: 3rem 0; max-width: 820px;"><h1>Privacy Policy</h1><p>Most TovolBox tools process input locally in your browser. We do not require accounts and do not collect psychological test answers.</p></section></BaseLayout>
