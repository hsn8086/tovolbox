---
import { getPageCopy } from '@/data/pageCopy';
import BaseLayout from '@/layouts/BaseLayout.astro';
const locale = 'en';
const pageCopy = getPageCopy(locale);
---
<BaseLayout locale={locale} title={`${pageCopy.privacyTitle} | TovolBox`} description={pageCopy.privacyDescription} route={{ locale, kind: 'privacy' }}>
  <section class="container" style="padding: 3rem 0; max-width: 820px; display: grid; gap: 1rem;">
    <h1>{pageCopy.privacyTitle}</h1>
    <p style="color: var(--muted); line-height: 1.7;">{pageCopy.privacyIntro}</p>
    <section class="card" style="padding: 1.25rem;"><h2>{pageCopy.privacyLocalHeading}</h2><p>{pageCopy.privacyLocalBody}</p></section>
    <section class="card" style="padding: 1.25rem;"><h2>{pageCopy.privacyAccountHeading}</h2><p>{pageCopy.privacyAccountBody}</p></section>
    <section class="card" style="padding: 1.25rem;"><h2>{pageCopy.privacyMentalHeading}</h2><p>{pageCopy.privacyMentalBody}</p></section>
  </section>
</BaseLayout>
