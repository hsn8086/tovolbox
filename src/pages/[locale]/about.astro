---
import { locales, type Locale } from '@/data/locales';
import BaseLayout from '@/layouts/BaseLayout.astro';
export function getStaticPaths() { return locales.filter((locale) => locale !== 'en').map((locale) => ({ params: { locale } })); }
const locale = Astro.params.locale as Locale;
---
<BaseLayout locale={locale} title="About TovolBox" description="About TovolBox." route={{ locale, kind: 'about' }}><section class="container" style="padding: 3rem 0; max-width: 820px;"><h1>About TovolBox</h1><p>TovolBox is a multilingual collection of practical web tools.</p></section></BaseLayout>
