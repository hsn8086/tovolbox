---
import { categories } from '@/data/content';
import { localeCopy, locales, type Locale } from '@/data/locales';
import BaseLayout from '@/layouts/BaseLayout.astro';
import { getLocalizedPath } from '@/lib/i18n/routing';
export function getStaticPaths() { return locales.filter((locale) => locale !== 'en').map((locale) => ({ params: { locale } })); }
const locale = Astro.params.locale as Locale;
const copy = localeCopy[locale];
---
<BaseLayout locale={locale} title={`${copy.allCategories} | TovolBox`} description={copy.tagline} route={{ locale, kind: 'categories' }}>
  <section class="container" style="padding: 3rem 0;"><h1>{copy.allCategories}</h1><div class="grid-auto">{categories.map((category) => <a class="card" style="padding: 1.1rem;" href={getLocalizedPath({ locale, kind: 'category', slug: category.slug })}><h2>{category.seo[locale].h1}</h2><p style="color: var(--muted);">{category.seo[locale].description}</p></a>)}</div></section>
</BaseLayout>
